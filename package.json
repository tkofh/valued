{
  "name": "valued",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "deps:reinstall": "pnpm dlx rimraf --glob node_modules packages/*/node_modules pnpm-lock.yaml && pnpm install",
    "deps:upgrade": "pnpm update --recursive --latest && pnpm dedupe",
    "typecheck": "turbo run check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "turbo run check && oxlint && oxfmt --check .",
    "fix": "oxlint --fix && oxfmt --write .",
    "test": "turbo run test",
    "version-packages": "changeset version && pnpm install --lockfile-only && pnpm run format"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "turbo": "^2.9.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
